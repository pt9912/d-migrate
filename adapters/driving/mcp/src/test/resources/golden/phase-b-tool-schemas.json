  "schema_compare": {
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "schemaRef": {
              "type": "string"
            }
          },
          "required": [
            "schemaRef"
          ]
        },
        "right": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "schemaRef": {
              "type": "string"
            }
          },
          "required": [
            "schemaRef"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "yaml"
          ]
        }
      },
      "required": [
        "left",
        "right"
      ]
    },
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "identical",
            "different"
          ]
        },
        "summary": {
          "type": "string"
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "severity": {
                "type": "string",
                "enum": [
                  "error",
                  "warning",
                  "info"
                ]
              },
              "code": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "additionalProperties": false,
                "minProperties": 1,
                "properties": {
                  "before": {
                    "type": "string",
                    "pattern": "\\S"
                  },
                  "after": {
                    "type": "string",
                    "pattern": "\\S"
                  }
                }
              }
            },
            "required": [
              "severity",
              "code",
              "path",
              "message"
            ]
          }
        },
        "truncated": {
          "type": "boolean"
        },
        "diffArtifactRef": {
          "type": "string",
          "pattern": "^dmigrate://tenants/[^/]+/artifacts/[^/]+$"
        },
        "executionMeta": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requestId": {
              "type": "string"
            }
          },
          "required": [
            "requestId"
          ]
        }
      },
      "required": [
        "status",
        "summary",
        "findings",
        "truncated"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "truncated": {
                "const": true
              }
            },
            "required": [
              "truncated"
            ]
          },
          "then": {
            "required": [
              "diffArtifactRef"
            ]
          }
        }
      ]
    }
  },
